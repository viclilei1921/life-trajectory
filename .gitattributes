# 默认：可识别为文本的文件在索引中归一化为 LF，检出时亦为 LF（跨平台协作）
* text=auto eol=lf

# 显式文本（避免个别环境对扩展名识别不一致）
*.css     text eol=lf
*.html    text eol=lf
*.js      text eol=lf
*.cjs     text eol=lf
*.mjs     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.svelte  text eol=lf
*.json    text eol=lf
*.jsonc   text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.toml    text eol=lf
*.rs      text eol=lf
*.svg     text eol=lf
*.xml     text eol=lf
*.sh      text eol=lf

# Windows 批处理在 cmd 下通常期望 CRLF
*.bat     text eol=crlf
*.cmd     text eol=crlf

# 二进制：禁止行尾转换与文本合并，避免损坏
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.ico     binary
*.icns    binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.otf     binary
*.eot     binary
*.pdf     binary
*.wasm    binary
*.zip     binary
*.7z      binary
*.gz      binary
*.exe     binary
*.dll     binary
*.so      binary
*.dylib   binary
*.mp3     binary
*.mp4     binary
*.webm    binary
*.wav     binary
*.glb     binary
*.gltf    text eol=lf
*.bin     binary

